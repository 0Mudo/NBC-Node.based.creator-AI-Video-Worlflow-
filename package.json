{
  "name": "node-based-creator",
  "private": true,
  "version": "1.0.5-beta-18",
  "description": "素材节点式图形界面 - Visual Asset Node Editor",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:build-main": "vite build --config vite.electron.config.ts",
    "electron:dev": "cmd /c \"for /f \\\"tokens=5\\\" %a in ('netstat -ano ^| findstr :5173 ^| findstr LISTENING') do taskkill /f /pid %a 2>nul\" & pnpm run electron:build-main & set VITE_DEV_SERVER_URL=http://localhost:5173 & concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:prod": "pnpm run build && pnpm run electron:build-main && electron .",
    "electron:build": "pnpm run build && pnpm run electron:build-main && electron-builder --win"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@types/three": "^0.184.1",
    "ali-oss": "^6.23.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "diff-match-patch": "^1.0.5",
    "lucide-react": "^0.344.0",
    "rc-dock": "^4.0.0-alpha.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.0",
    "tailwind-merge": "^2.2.1",
    "three": "^0.184.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/diff-match-patch": "^1.0.36",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nbc.creator",
    "productName": "NBC 节点式素材创作器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NBC 创作器"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "fileAssociations": [
      {
        "ext": "nbc.json",
        "name": "NBC Workflow",
        "description": "NBC 工作流文件",
        "role": "Editor"
      }
    ],
    "protocols": [
      {
        "name": "NBC Deep Link",
        "schemes": [
          "nbc"
        ]
      }
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
